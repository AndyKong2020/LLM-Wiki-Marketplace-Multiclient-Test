#!/usr/bin/env bash
set -euo pipefail

repo="https://github.com/{{test_repository}}.git"
ref="{{test_ref}}"
workdir="${TMPDIR:-/tmp}/llm-wiki-opencode-bootstrap.$$"

cleanup() {
  rm -rf "${workdir}"
}
trap cleanup EXIT

git clone --depth 1 --branch "${ref}" "${repo}" "${workdir}"
bash "${workdir}/dist/opencode/install-opencode.sh" "$@"
